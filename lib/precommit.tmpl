#!/usr/bin/env bash
# Auto-generated by `kb init`. Validates staged KB entries before commit.
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"
BIN="$ROOT/.kb/bin"
STAGED="$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)"
[ -z "$STAGED" ] && exit 0
# shellcheck disable=SC2086
ABS=$(printf '%s\n' $STAGED | sed "s|^|$ROOT/|")
rc=0
bash "$BIN/validate.sh" --root "$ROOT" $ABS || rc=1
enabled() { jq -r --arg c "$1" '.checks[$c] // false' "$ROOT/kb.json" 2>/dev/null; }
[ "$(enabled wikilinks)" = "true" ]         && { bash "$BIN/check-wikilinks.sh"  --root "$ROOT" $ABS || rc=1; }
[ "$(enabled ghostLinks)" = "true" ]        && { bash "$BIN/check-ghostlinks.sh" --root "$ROOT" $ABS || rc=1; }
[ "$(enabled graphConnectivity)" = "true" ] && { bash "$BIN/check-graph.sh"      --root "$ROOT" $ABS || rc=1; }
exit $rc
