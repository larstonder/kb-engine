#!/usr/bin/env bash
# bin/kb - scaffold and sync a KB content repo.
set -uo pipefail
ENGINE_DIR="$(cd "$(dirname "$0")/.." && pwd)"

die() { echo "kb: $1" >&2; exit 1; }

cmd_init() {
  local dir="" preset="general" cats="" mode="standalone" branch="main" project="$PWD" autocommit="" force=""
  dir="$1"; shift || true
  [ -n "$dir" ] || die "usage: kb init <dir> [--preset X] [--categories a,b] [--mode M] [--branch B] [--project P]"
  while [ $# -gt 0 ]; do case "$1" in
    --preset)     preset="$2";  shift 2;;
    --categories) cats="$2";    shift 2;;
    --mode)         mode="$2";    shift 2;;
    --branch)       branch="$2";  shift 2;;
    --project)      project="$2"; shift 2;;
    --auto-commit)    autocommit="true";  shift;;
    --no-auto-commit) autocommit="false"; shift;;
    --force)          force="1";          shift;;
    *) die "unknown flag: $1";;
  esac; done
  case "$mode" in standalone|submodule|inrepo) ;; *) die "mode must be standalone, submodule, or inrepo";; esac
  if [ -z "$autocommit" ]; then
    if [ "$mode" = "inrepo" ]; then autocommit="false"; else autocommit="true"; fi
  fi
  local presetf="$ENGINE_DIR/presets/$preset.json"
  [ -f "$presetf" ] || die "no such preset: $preset"
  mkdir -p "$dir"
  # kb.json from preset, optionally overriding category list.
  if [ -f "$dir/kb.json" ] && [ -z "$force" ]; then
    echo "kb: kb.json already exists; leaving it (use --force to overwrite)"
  elif [ -n "$cats" ]; then
    local arr; arr="$(printf '%s' "$cats" | jq -R 'split(",")|map({name:.,type:.})')"
    jq --argjson c "$arr" '.categories=$c' "$presetf" > "$dir/kb.json"
  else
    cp "$presetf" "$dir/kb.json"
  fi
  # Category folders.
  while IFS= read -r c; do mkdir -p "$dir/$c"; done < <(jq -r '.categories[].name' "$dir/kb.json")
  # Content-template docs (do not clobber existing).
  for fdoc in CONVENTIONS.md INDEX.md BACKLOG.md README.md .gitignore .gitattributes; do
    [ -f "$dir/$fdoc" ] || cp "$ENGINE_DIR/content-template/$fdoc" "$dir/$fdoc"
  done
  vendor "$dir"
  if [ "$mode" = "standalone" ] && [ ! -d "$dir/.git" ]; then
    git -C "$dir" init -q
    git -C "$dir" symbolic-ref HEAD "refs/heads/$branch" 2>/dev/null || true
  fi
  install_hook "$dir"
  # Project .kbconfig (KB_DIR relative to project if possible).
  local rel; rel="$(python3 - "$project" "$dir" 2>/dev/null <<'PY'
import os, sys; print(os.path.relpath(sys.argv[2], sys.argv[1]))
PY
)"; [ -n "$rel" ] || rel="$dir"
  printf 'KB_DIR="%s"\nMODE="%s"\nAUTO_COMMIT="%s"\nBRANCH="%s"\n' "$rel" "$mode" "$autocommit" "$branch" > "$project/.kbconfig"
  echo "kb: initialized $dir (preset=$preset, mode=$mode)"
  if [ "$mode" = "inrepo" ]; then
    echo "kb: inrepo mode - the KB is tracked by your main repo (do not gitignore it)."
    echo "    To validate your own commits, call $dir/.kb/bin/validate.sh from your project's pre-commit."
  fi
}

vendor() {
  local dir="$1"; mkdir -p "$dir/.kb/bin"
  cp "$ENGINE_DIR"/lib/validate.sh "$ENGINE_DIR"/lib/check-*.sh "$ENGINE_DIR"/lib/template.sh "$dir/.kb/bin/"
  chmod +x "$dir/.kb/bin/"*.sh
}

install_hook() {
  local dir="$1"
  [ -d "$dir/.git" ] || return 0
  mkdir -p "$dir/.git/hooks"
  cp "$ENGINE_DIR/lib/precommit.tmpl" "$dir/.git/hooks/pre-commit"
  chmod +x "$dir/.git/hooks/pre-commit"
}

cmd_sync() {
  local project="$PWD"
  while [ $# -gt 0 ]; do case "$1" in --project) project="$2"; shift 2;; *) die "unknown flag: $1";; esac; done
  # shellcheck disable=SC1091
  . "$ENGINE_DIR/lib/config.sh"
  CLAUDE_PROJECT_DIR="$project" kb_load_config || die "no .kbconfig in $project"
  vendor "$KB_DIR_ABS"; install_hook "$KB_DIR_ABS"
  while IFS= read -r c; do mkdir -p "$KB_DIR_ABS/$c"; done < <(jq -r '.categories[].name' "$KB_DIR_ABS/kb.json")
  echo "kb: synced $KB_DIR_ABS"
}

cmd_doctor() {
  local project="$PWD"
  while [ $# -gt 0 ]; do case "$1" in --project) project="$2"; shift 2;; *) shift;; esac; done
  local fail=0
  d_ok()   { printf 'ok   %s\n' "$1"; }
  d_warn() { printf 'warn %s\n' "$1"; }
  d_fail() { printf 'fail %s\n' "$1"; fail=1; }

  command -v jq  >/dev/null 2>&1 && d_ok "jq present" || d_fail "jq not found on PATH (required)"
  command -v git >/dev/null 2>&1 && d_ok "git present" || d_fail "git not found on PATH (required)"
  if command -v ruby >/dev/null 2>&1 || { command -v python3 >/dev/null 2>&1 && python3 -c 'import yaml' >/dev/null 2>&1; }; then
    d_ok "YAML parser present (strict frontmatter validation)"
  else
    d_warn "no ruby/python yaml parser; using portable fallback"
  fi

  # shellcheck disable=SC1091
  . "$ENGINE_DIR/lib/config.sh"
  if CLAUDE_PROJECT_DIR="$project" kb_load_config; then
    d_ok ".kbconfig found (KB_DIR=$KB_DIR_ABS, MODE=$KB_MODE, AUTO_COMMIT=$KB_AUTO_COMMIT)"
    [ -d "$KB_DIR_ABS" ] && d_ok "KB_DIR exists" || d_fail "KB_DIR does not exist: $KB_DIR_ABS"
  else
    d_fail "no .kbconfig in $project (run: kb init <dir>)"
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    if [ -f "$KB_DIR_ABS/kb.json" ] && jq -e . "$KB_DIR_ABS/kb.json" >/dev/null 2>&1; then
      local v; v="$(kb_kbjson_version)"
      if [ "$v" -le "$KB_SCHEMA_VERSION" ] 2>/dev/null; then d_ok "kb.json valid (version $v)"
      else d_warn "kb.json version $v > engine $KB_SCHEMA_VERSION; update the plugin"; fi
    else
      d_fail "kb.json missing or invalid JSON"
    fi
  else
    d_warn "kb.json not checked (jq missing)"
  fi

  local s missing=0
  for s in validate.sh check-wikilinks.sh check-ghostlinks.sh check-graph.sh template.sh; do
    [ -x "$KB_DIR_ABS/.kb/bin/$s" ] || { d_fail "vendored validator missing/not executable: .kb/bin/$s"; missing=1; }
  done
  [ "$missing" = 0 ] && d_ok "vendored validators present (.kb/bin/)"

  case "$KB_MODE" in
    inrepo)
      git -C "$KB_DIR_ABS" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
        && d_ok "KB_DIR is inside a git repo (inrepo)" \
        || d_fail "inrepo: KB_DIR is not inside a git repo"
      d_warn "inrepo: no pre-commit installed; validation runs at Stop"
      ;;
    *)
      git -C "$KB_DIR_ABS" rev-parse --git-dir >/dev/null 2>&1 \
        && d_ok "KB_DIR is a git repo" || d_fail "KB_DIR is not a git repo"
      [ -x "$KB_DIR_ABS/.git/hooks/pre-commit" ] \
        && d_ok "pre-commit hook installed" || d_warn "pre-commit not installed (run: kb sync)"
      if git -C "$KB_DIR_ABS" remote get-url origin >/dev/null 2>&1; then
        git -C "$KB_DIR_ABS" ls-remote --exit-code origin >/dev/null 2>&1 \
          && d_ok "remote reachable" || d_warn "remote configured but unreachable (offline?)"
      else
        d_warn "no remote configured (local-only)"
      fi
      ;;
  esac

  [ "$fail" = 0 ] && { printf 'kb doctor: OK\n'; return 0; } || { printf 'kb doctor: problems found\n'; return 1; }
}

case "${1:-}" in
  init) shift; cmd_init "$@";;
  sync) shift; cmd_sync "$@";;
  doctor) shift; cmd_doctor "$@";;
  *) die "usage: kb {init|sync|doctor} ...";;
esac
